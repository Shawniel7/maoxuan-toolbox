# Copy this file to backend/.env and fill in values.
# backend/.env is gitignored (top-level .env pattern).

# ---- LLM (required for agent.py; NOT needed for corpus construction) ----
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Model used by the agent. Defaults to claude-sonnet-4-6 if unset.
# Options: claude-opus-4-7, claude-sonnet-4-6, claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Embedding provider ----
# local   : BAAI/bge-small-zh-v1.5 via sentence-transformers (default, free, offline)
# voyage  : Voyage AI (needs VOYAGE_API_KEY). Better Chinese quality, paid.
# openai  : OpenAI text-embedding-3-small (needs OPENAI_API_KEY). Paid.
EMBEDDING_PROVIDER=local

VOYAGE_API_KEY=
OPENAI_API_KEY=

# ---- RAG tuning ----
RAG_TOP_K=8
RAG_RERANK=true
RAG_RERANK_MODEL=claude-haiku-4-5-20251001

# ---- Crawler tuning ----
CRAWL_MIN_DELAY_SEC=1.5
CRAWL_MAX_DELAY_SEC=3.0
CRAWL_MAX_RETRIES=3
CRAWL_USER_AGENT=MaoxuanToolbox/1.0 (educational; respects robots.txt)

# ---- Server ----
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
